import tkinter as tk
from tkinter import ttk
import subprocess
import threading
import os

class InstallerApp:
    def __init__(self, root):
        self.root = root
        root.title("Claude Suite Installer")
        root.geometry("600x400")

        self.progress = ttk.Progressbar(root, length=500)
        self.progress.pack(pady=10)

        self.log = tk.Text(root, height=15)
        self.log.pack(pady=10)

        self.button = tk.Button(root, text="Installer / Réinstaller", command=self.start_install)
        self.button.pack(pady=10)

        self.steps = [
            ("Vérification Homebrew", "which brew || /bin/bash -c \"$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)\""),
            ("Installation Node.js", "brew install node"),
            ("Installation Claude Code", "brew install anthropic/tap/claude"),
            ("Téléchargement Claude Desktop", "curl -L -o ~/Downloads/Claude.dmg https://claude.ai/download"),
            ("Installation Claude Desktop", "hdiutil attach ~/Downloads/Claude.dmg && cp -R /Volumes/Claude/Claude.app /Applications && hdiutil detach /Volumes/Claude"),
            ("Installation MCP Figma", "npm install -g @modelcontextprotocol/server-figma"),
            ("Configuration MCP", "mkdir -p ~/.config/mcp && echo '{\"mcpServers\":{\"figma\":{\"command\":\"npx\",\"args\":[\"@modelcontextprotocol/server-figma\"]}}}' > ~/.config/mcp/config.json")
        ]

    def log_message(self, message):
        self.log.insert(tk.END, message + "\n")
        self.log.see(tk.END)

    def run_command(self, command):
        process = subprocess.Popen(command, shell=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)
        for line in process.stdout:
            self.log_message(line.decode().strip())
        process.wait()

    def start_install(self):
        self.button.config(state=tk.DISABLED)
        thread = threading.Thread(target=self.install)
        thread.start()

    def install(self):
        total = len(self.steps)
        for i, (label, cmd) in enumerate(self.steps):
            self.log_message(f"🔧 {label}...")
            self.run_command(cmd)
            self.progress["value"] = ((i + 1) / total) * 100

        self.log_message("✅ Installation terminée")
        self.button.config(state=tk.NORMAL)

if __name__ == "__main__":
    root = tk.Tk()
    app = InstallerApp(root)
    root.mainloop()