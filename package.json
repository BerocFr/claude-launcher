{
  "name": "claude-launcher",
  "version": "1.1.0",
  "description": "Turnkey installer for Claude, Claude Code & MCP on macOS",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder",
    "dist:arm64": "npm run build && electron-builder --arm64",
    "dist:x64": "npm run build && electron-builder --x64"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.3.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^3.6.0",
    "@types/node": "^20.10.4",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "electron-vite": "^2.0.0",
    "lucide-react": "^0.300.0",
    "postcss": "^8.4.32",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.anthropic.claude-launcher",
    "productName": "Claude Launcher",
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": false,
      "identity": null,
      "minimumSystemVersion": "12.0",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "sign": false,
      "window": {
        "width": 540,
        "height": 380
      },
      "iconSize": 80,
      "contents": [
        {
          "x": 140,
          "y": 185,
          "type": "file"
        },
        {
          "x": 400,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "directories": {
      "buildResources": "resources"
    },
    "asar": true
  }
}
